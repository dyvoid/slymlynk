<Window x:Class="SlymLynk.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:SlymLynk.ViewModels"
        Title="SlymLynk"
        Width="300" Height="300"
        MinWidth="300" MinHeight="300"
        MaxWidth="300" MaxHeight="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#181825"
        AllowDrop="True"
        Drop="Window_Drop"
        DragEnter="Window_DragEnter"
        DragOver="Window_DragOver">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>

    <Grid>
        <!-- Idle state -->
        <Grid Visibility="{Binding IsIdle, Converter={StaticResource BoolToVisibility}}">
            <Border CornerRadius="8" Margin="16" BorderBrush="#313244" BorderThickness="2">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="Drop a file or folder here"
                               Foreground="#CDD6F4" FontSize="14"
                               TextAlignment="Center" TextWrapping="Wrap" />
                    <TextBlock Text="or click to browse"
                               Foreground="#6C7086" FontSize="11"
                               TextAlignment="Center" Margin="0,6,0,0" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Source loaded state -->
        <Grid Visibility="{Binding IsSourceLoaded, Converter={StaticResource BoolToVisibility}}">
            <Border CornerRadius="8" Margin="16" BorderBrush="#A6E3A1" BorderThickness="2">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,0">
                        <TextBlock Text="Ready to link"
                                   Foreground="#A6E3A1" FontSize="13" FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding SourceDisplayName}"
                                   Foreground="#CDD6F4" FontSize="12"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                        <TextBlock Text="Drag out to link, or click to choose destination"
                                   Foreground="#6C7086" FontSize="11"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                        <Button Content="Choose destination…"
                                Command="{Binding SaveToDestinationCommand}"
                                Margin="0,12,0,0"
                                Padding="12,6"
                                Background="#313244" Foreground="#CDD6F4"
                                BorderThickness="0" Cursor="Hand" />
                    </StackPanel>

                    <Button Content="✕"
                            Command="{Binding ClearCommand}"
                            Width="24" Height="24"
                            VerticalAlignment="Top" HorizontalAlignment="Right"
                            Margin="0,4,4,0"
                            Background="Transparent" Foreground="#6C7086"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="11" />
                </Grid>
            </Border>
        </Grid>

        <!-- Error state -->
        <Grid Visibility="{Binding IsError, Converter={StaticResource BoolToVisibility}}">
            <Border CornerRadius="8" Margin="16" BorderBrush="#F38BA8" BorderThickness="2">
                <Grid>
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="16,0">
                        <TextBlock Text="Something went wrong"
                                   Foreground="#F38BA8" FontSize="13" FontWeight="SemiBold"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#CDD6F4" FontSize="11"
                                   TextAlignment="Center" TextWrapping="Wrap"
                                   Margin="0,8,0,0" />
                    </StackPanel>

                    <Button Content="✕"
                            Command="{Binding ClearCommand}"
                            Width="24" Height="24"
                            VerticalAlignment="Top" HorizontalAlignment="Right"
                            Margin="0,4,4,0"
                            Background="Transparent" Foreground="#6C7086"
                            BorderThickness="0" Cursor="Hand"
                            FontSize="11" />
                </Grid>
            </Border>
        </Grid>

    </Grid>
</Window>
